# gitignore
# variaveis do ambiente e segredo
.env
.env.local
.env.development
.env.staging
.env.production
*.pem
*.key
secrets.json

# dependencias
node_modules/
bower_components/
.pnp
.pnp.js
package-lock.json
yarn.lock
pnpm-lock.yaml

# build e distribuição
dist/
build/
out/
.output/
*.min.js
*.min.css
*.bundle.js

# caches de ferramentas
.cache/
.parcel-cache/
.vite/
.eslintcache
.stylelintcache
.prettiercache
.turbo/

# editores e ides
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*~

# sistema operacional
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# testes e coberturas
coverage/
.nyc_output/
test-results/
playwright-report/
cypress/videos/
cypress/screenshots/

# asssets gerados e temporarios
src/assets/images/thumbs/
*.tmp
*.temp
*.bak
*.orig

# documentacao gerada
docs/_site/
docs/.jekyll-cache/

# deployment 
.netlify/
.vercel/
.firebase/
firebase-debug.log

# analise de budle
stats.json
bundle-analyzer-report.html